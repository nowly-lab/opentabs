{
  "name": "@opentabs-dev/opentabs-plugin-mercari",
  "version": "0.1.0",
  "description": "OpenTabs plugin for Mercari Japan sourcing research",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && opentabs-plugin build",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "check": "npm run build && npm run type-check && npm run lint && npm run format:check"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@opentabs-dev/plugin-sdk": "latest",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@opentabs-dev/plugin-tools": "latest",
    "typescript": "^5.9.0"
  },
  "opentabs": {
    "displayName": "Mercari",
    "description": "Search Mercari Japan and read item details for sourcing analysis",
    "homepage": "https://jp.mercari.com/",
    "urlPatterns": [
      "*://jp.mercari.com/*"
    ]
  }
}
